{
  "tests": [
    {
      "description": "Hyphenated drug - SOLU-medrol",
      "input": "solu-medrol",
      "listId": "DEFAULT",
      "expected": "SOLU-medrol"
    },
    {
      "description": "Hyphenated drug - DEPO-medrol",
      "input": "depo-medrol",
      "listId": "DEFAULT",
      "expected": "DEPO-medrol"
    },
    {
      "description": "Hyphenated drug - solu-CORTEF",
      "input": "solu-cortef",
      "listId": "DEFAULT",
      "expected": "solu-CORTEF"
    },
    {
      "description": "Hyphenated drug - depo-PROVERA",
      "input": "depo-provera",
      "listId": "DEFAULT",
      "expected": "depo-PROVERA"
    },
    {
      "description": "Hyphenated drug - uppercase input",
      "input": "SOLU-MEDROL",
      "listId": "DEFAULT",
      "expected": "SOLU-medrol"
    },
    {
      "description": "Hyphenated drug in sentence",
      "input": "Patient prescribed solu-medrol today",
      "listId": "DEFAULT",
      "expected": "Patient prescribed SOLU-medrol today"
    },
    {
      "description": "Multi-word with space - MS Contin",
      "input": "ms contin",
      "listId": "DEFAULT",
      "expected": "MS Contin"
    },
    {
      "description": "Multi-word with space - isopto CARpine",
      "input": "isopto carpine",
      "listId": "DEFAULT",
      "expected": "isopto CARpine"
    },
    {
      "description": "Multi-word with space - isopto HOMATROpine",
      "input": "isopto homatropine",
      "listId": "DEFAULT",
      "expected": "isopto HOMATROpine"
    },
    {
      "description": "Alternative form in parentheses - ciclosPORIN (cyclosPORIN)",
      "input": "ciclosporin (cyclosporin)",
      "listId": "DEFAULT",
      "expected": "ciclosPORIN (cyclosPORIN)"
    },
    {
      "description": "Standalone cefalexin converts to cefaLEXin",
      "input": "cefalexin",
      "listId": "DEFAULT",
      "expected": "cefaLEXin"
    },
    {
      "description": "Alternative form in parentheses partially Tallman - cefaLEXin (cephaLEXin)",
      "input": "cefalexin (cephaLEXin)",
      "listId": "DEFAULT",
      "expected": "cefaLEXin (cephaLEXin)"
    },
    {
      "description": "Multiple hyphenated drugs in sentence",
      "input": "Choose between solu-medrol and depo-medrol",
      "listId": "DEFAULT",
      "expected": "Choose between SOLU-medrol and DEPO-medrol"
    },
    {
      "description": "Hyphen should create word boundary",
      "input": "test-prednisone-test",
      "listId": "DEFAULT",
      "expected": "test-predniSONE-test"
    },
    {
      "description": "3-word entry match - methylprednisolone SODIUM SUCCINate (NZ list, lowercase input)",
      "input": "methylprednisolone sodium succinate",
      "listId": "NZ",
      "expected": "methylprednisolone SODIUM SUCCINate"
    },
    {
      "description": "3-word entry match in sentence (NZ list)",
      "input": "Administer methylprednisolone sodium succinate intravenously",
      "listId": "NZ",
      "expected": "Administer methylprednisolone SODIUM SUCCINate intravenously"
    },
    {
      "description": "3-word entry match - mixed case input normalizes (NZ list)",
      "input": "Methylprednisolone Sodium Succinate",
      "listId": "NZ",
      "expected": "methylprednisolone SODIUM SUCCINate"
    },
    {
      "description": "Multi-word case variant - all uppercase (MS CONTIN -> MS Contin)",
      "input": "MS CONTIN",
      "listId": "DEFAULT",
      "expected": "MS Contin"
    },
    {
      "description": "Multi-word case variant - title case (Ms Contin -> MS Contin)",
      "input": "Ms Contin",
      "listId": "DEFAULT",
      "expected": "MS Contin"
    },
    {
      "description": "Multi-word fallback - first word of ms contin entry present but second word differs (no partial match)",
      "input": "ms aspirin",
      "listId": "DEFAULT",
      "expected": "ms aspirin"
    },
    {
      "description": "Multi-word fallback - first word of multi-word entry is not a standalone entry",
      "input": "ms",
      "listId": "DEFAULT",
      "expected": "ms"
    }
  ]
}
