{
  "tests": [
    {
      "description": "Drug name followed by comma",
      "input": "prednisone, erythromycin",
      "listId": "DEFAULT",
      "expected": "predniSONE, ERYthromycin"
    },
    {
      "description": "Drug name followed by period",
      "input": "The medication is prednisone.",
      "listId": "DEFAULT",
      "expected": "The medication is predniSONE."
    },
    {
      "description": "Drug name in parentheses",
      "input": "Steroid (prednisone) prescribed",
      "listId": "DEFAULT",
      "expected": "Steroid (predniSONE) prescribed"
    },
    {
      "description": "Drug name with exclamation",
      "input": "Not prednisone!",
      "listId": "DEFAULT",
      "expected": "Not predniSONE!"
    },
    {
      "description": "Drug name with question mark",
      "input": "Is it prednisone?",
      "listId": "DEFAULT",
      "expected": "Is it predniSONE?"
    },
    {
      "description": "Drug name in quotes",
      "input": "The drug \"prednisone\" was prescribed",
      "listId": "DEFAULT",
      "expected": "The drug \"predniSONE\" was prescribed"
    },
    {
      "description": "Drug name with colon",
      "input": "Medication: prednisone",
      "listId": "DEFAULT",
      "expected": "Medication: predniSONE"
    },
    {
      "description": "Drug name with semicolon",
      "input": "prednisone; oxcarbazepine; morphine",
      "listId": "DEFAULT",
      "expected": "predniSONE; OXCARBazepine; morphine"
    },
    {
      "description": "Multiple punctuation types",
      "input": "prednisone, morphine; hydromorphone.",
      "listId": "DEFAULT",
      "expected": "predniSONE, morphine; HYDROmorphone."
    },
    {
      "description": "No-space punctuation adjacency - comma with no surrounding spaces (spec 8.3)",
      "input": "prednisone,prednisone",
      "listId": "DEFAULT",
      "expected": "predniSONE,predniSONE"
    },
    {
      "description": "Possessive apostrophe is a word boundary - drug name before apostrophe-s converts",
      "input": "prednisone's",
      "listId": "DEFAULT",
      "expected": "predniSONE's"
    },
    {
      "description": "Multi-word drug in parentheses - parentheses are word boundaries",
      "input": "(ms contin)",
      "listId": "DEFAULT",
      "expected": "(MS Contin)"
    },
    {
      "description": "Hyphenated drug with trailing comma - comma is word boundary after second component",
      "input": "solu-medrol,",
      "listId": "DEFAULT",
      "expected": "SOLU-medrol,"
    }
  ]
}
